NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
DEEPGRAM_API_KEY=your-deepgram-key
# OPENAI_API_KEY is your OpenRouter API key (sk-or-v1-...), or your OpenAI key
# if you set OPENAI_BASE_URL to https://api.openai.com/v1
OPENAI_API_KEY=sk-or-v1-your-openrouter-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# WORKER_AUTH_TOKEN is auto-generated if omitted
# WORKER_AUTH_TOKEN=your-worker-token
# OPENAI_BASE_URL defaults to https://openrouter.ai/api/v1 — uncomment to use
# native OpenAI instead:
# OPENAI_BASE_URL=https://api.openai.com/v1
