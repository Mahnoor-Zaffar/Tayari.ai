# ── API ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Feature flags ───────────────────────────────────────────────────────
# Set to "1" or "true" to enable, "0" or "false" to disable.
# Unset = default value (shown after the colon).
NEXT_PUBLIC_FF_INTERVIEWS=0   # default: false — /dashboard/interviews
NEXT_PUBLIC_FF_REPORTS=0      # default: false — /dashboard/reports
NEXT_PUBLIC_FF_BILLING=0      # default: false — /dashboard/billing
NEXT_PUBLIC_FF_SETTINGS=0     # default: false — /dashboard/settings
NEXT_PUBLIC_FF_NEW_INTERVIEW=1  # default: true
NEXT_PUBLIC_FF_ANALYTICS=1      # default: true

# ── Performance ─────────────────────────────────────────────────────────
# ANALYZE=true next build  — generates bundle report in .next/analyze/
