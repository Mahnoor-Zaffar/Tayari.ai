{
  "name": "@tayari/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "lint": "ruff check .",
    "typecheck": "mypy .",
    "test": "pytest",
    "clean": "find . -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null; rm -rf .venv .pytest_cache .ruff_cache .mypy_cache"
  }
}
